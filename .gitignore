# --- Dependencies ---
# This ignores the massive folder containing your installed packages
node_modules/
jspm_packages/

# --- Environment / Secrets ---
# NEVER commit these. They contain passwords, API keys, and private data.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.bak

# --- Build / Output ---
# Ignores the folders generated when you "build" your project for production
dist/
build/
out/
.cache/

# --- Logs ---
# Ignores log files generated by npm/yarn/system
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Testing & Coverage ---
# Ignores report folders generated by test runners (like Jest)
coverage/
.nyc_output/

# --- OS / Editor Specific ---
# macOS system files
.DS_Store
# Windows system files
Thumbs.db
# VS Code settings (it's better to share settings via a separate config, not git)
.vscode/
# JetBrains/IntelliJ settings
.idea/
